<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Content (shown when logged in & data available) -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: "Kirana AI" wordmark + "updated" stamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_brand_kirana"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="@string/widget_brand_ai"
                android:textColor="#F59E0B"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:02 AM"
                android:textColor="#8A9BBF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Row 1: Sales | Udhaar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cell_sales"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/sales_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹12,400"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sales_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today\'s Sales"
                    android:textColor="#AEBBD4"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/sales_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18 orders"
                    android:textColor="#AEBBD4"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cell_udhaar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/udhaar_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹3,200"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/udhaar_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Udhaar Due"
                    android:textColor="#AEBBD4"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/udhaar_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 overdue"
                    android:textColor="#AEBBD4"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Low Stock | Pay Today -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cell_stock"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/stock_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/stock_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low Stock"
                    android:textColor="#AEBBD4"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/stock_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="items"
                    android:textColor="#AEBBD4"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cell_supplier"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/supplier_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹4,000"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/supplier_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pay Today"
                    android:textColor="#AEBBD4"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/supplier_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 to pay"
                    android:textColor="#AEBBD4"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- New Bill action -->
        <TextView
            android:id="@+id/btn_newbill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:text="+ New Bill"
            android:textColor="#243B6B"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Empty / logged-out state -->
    <TextView
        android:id="@+id/empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="#AEBBD4"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
