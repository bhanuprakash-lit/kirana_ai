  "supEmailError": "ಇಮೇಲ್ ಅಪ್ಲಿಕೇಶನ್ ತೆರೆಯುವಾಗ ಏನೋ ತಪ್ಪಾಗಿದೆ.",
  "supFaqTitle": "FAQ ಗಳು",
  "supFaqQ1": "ಹೊಸ ಉತ್ಪನ್ನವನ್ನು ಹೇಗೆ ಸೇರಿಸುವುದು?",
  "supFaqA1": "POS ಟ್ಯಾಬ್‌ನಲ್ಲಿ + ಬಟನ್ ಕ್ಲಿಕ್ ಮಾಡುವ ಮೂಲಕ ಅಥವಾ ದಾಸ್ತಾನು ಟ್ಯಾಬ್‌ನಿಂದ ಉತ್ಪನ್ನಗಳನ್ನು ಸೇರಿಸಬಹುದು. ಲಭ್ಯವಿದ್ದರೆ ವಿವರಗಳನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಪಡೆಯಲು ಬಾರ್‌ಕೋಡ್ ಸ್ಕ್ಯಾನ್ ಮಾಡಬಹುದು.",
  "supFaqQ2": "ಸ್ಟಾಕ್ ಮುಗಿಯುವ ಅಪಾಯದ ಮುನ್ಸೂಚನೆ ಹೇಗೆ ಕೆಲಸ ಮಾಡುತ್ತದೆ?",
  "supFaqA2": "ನಮ್ಮ AI ನಿಮ್ಮ ಹಿಂದಿನ ಮಾರಾಟ ವೇಗ ಮತ್ತು ಪ್ರಸ್ತುತ ಸ್ಟಾಕ್ ಮಟ್ಟಗಳನ್ನು ವಿಶ್ಲೇಷಿಸುತ್ತದೆ. ಮುಂದಿನ 3-7 ದಿನಗಳಲ್ಲಿ ವಸ್ತು ಖಾಲಿಯಾಗುತ್ತದೆ ಎಂದು ಊಹಿಸಿದರೆ, ಅದನ್ನು ಸ್ಟಾಕ್ ಮುಗಿಯುವ ಅಪಾಯ ಎಂದು ಗುರುತಿಸುತ್ತದೆ.",
  "supFaqQ3": "ಗ್ರಾಹಕ ಸಾಲ (ಖಾತಾ) ಹೇಗೆ ನಿರ್ವಹಿಸುವುದು?",
  "supFaqA3": "ಆರ್ಡರ್ ಮಾಡುವಾಗ, ಗ್ರಾಹಕರನ್ನು ಆರಿಸಿ ಪಾವತಿ ವಿಧಾನವಾಗಿ \"ಸಾಲ\" ಆರಿಸಿ. ಎಲ್ಲಾ ಬಾಕಿಗಳನ್ನು ಹಣಕಾಸು -> ಉಧಾರ್ ಟ್ಯಾಬ್ ಅಥವಾ ಗ್ರಾಹಕ ಸಂಬಂಧಗಳ ವಿಭಾಗದಲ್ಲಿ ವೀಕ್ಷಿಸಬಹುದು.",
  "supFaqQ4": "ನನ್ನ ಫೋನ್ ಸಂಪರ್ಕಗಳನ್ನು ಸಿಂಕ್ ಮಾಡಬಹುದೇ?",
  "supFaqA4": "ಹೌದು! ಪ್ರೊಫೈಲ್ -> ಗ್ರಾಹಕ ಸಂಬಂಧಗಳಿಗೆ ಹೋಗಿ ಸಿಂಕ್ ಐಕಾನ್ ಕ್ಲಿಕ್ ಮಾಡಿ. ಇದು ಸುಲಭ ಸಾಲ ಟ್ರ್ಯಾಕಿಂಗ್‌ಗಾಗಿ ನಿಮ್ಮ ನಿಯಮಿತ ಗ್ರಾಹಕರನ್ನು ಅಪ್ಲಿಕೇಶನ್‌ಗೆ ಆಮದು ಮಾಡುತ್ತದೆ.",
  "supFaqQ5": "KPI ಚಂದಾದಾರಿಕೆಗಳು ಎಂದರೇನು?",
  "supFaqA5": "KPIಗಳು ಆದಾಯ, ಮಾರ್ಜಿನ್ ಮತ್ತು ಗ್ರಾಹಕ ಸಂಖ್ಯೆಯಂತಹ ಪ್ರಮುಖ ವ್ಯಾಪಾರ ಮೆಟ್ರಿಕ್‌ಗಳು. ಪ್ರೊಫೈಲ್ -> ಚಂದಾದಾರಿಕೆ ವಿಭಾಗದಿಂದ ಯಾವ ಮೆಟ್ರಿಕ್‌ಗಳನ್ನು ಮೇಲ್ವಿಚಾರಣೆ ಮಾಡಬೇಕೆಂದು ಆರಿಸಬಹುದು.",
  "supFaqQ6": "ದೈನಂದಿನ ಮಾರಾಟ ವರದಿಯನ್ನು ಹೇಗೆ ರಚಿಸುವುದು?",
  "supFaqA6": "ಇಂದಿನ ಕಾರ್ಯಕ್ಷಮತೆಯನ್ನು ಡ್ಯಾಶ್‌ಬೋರ್ಡ್‌ನಲ್ಲಿ ವೀಕ್ಷಿಸಬಹುದು. ವಿವರವಾದ ಹಿಂದಿನ ವರದಿಗಳಿಗಾಗಿ, ನಿಮ್ಮ ಪ್ರೊಫೈಲ್‌ನಲ್ಲಿನ ವಹಿವಾಟು ಇತಿಹಾಸ ವಿಭಾಗಕ್ಕೆ ಭೇಟಿ ನೀಡಿ.",
